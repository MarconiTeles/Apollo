<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Sparkle Downloader.xpc — fetches the .zip update package
        from the appcast's <enclosure> URL. Sandboxed (network
        only) so a compromised download payload can't reach
        outside the XPC's container.

        Application Group identifier MUST match the one declared
        on the main app's Apollo.entitlements — Sparkle uses the
        group as the rendezvous point for XPC + shared
        UserDefaults between the main app and its helpers.
        Format is always `<TEAMID>.<bundle-id>`.
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>CU544M36UD.com.painellunar.app</string>
    </array>
</dict>
</plist>
