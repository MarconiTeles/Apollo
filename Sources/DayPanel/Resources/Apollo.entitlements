<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        ╔══════════════════════════════════════════════════════════╗
        ║  Apollo entitlements (Developer ID-signed builds)         ║
        ╚══════════════════════════════════════════════════════════╝

        Sandbox is back on as of 1.5.0. The previous attempt
        (1.4.10 / 1.4.11) failed because Sparkle's Installer
        XPC needs an Application Group keyed by `<TEAMID>.<bundle>`
        to gain system authorization, and adhoc binaries have no
        Team ID. Now that we sign with Developer ID
        `CU544M36UD`, the XPC services live inside an
        application-group entitlement and OTA installs work in
        sandbox.

          • app-sandbox            — confines the process to its
                                     container + declared
                                     capabilities.

          • network.client         — outbound HTTPS to ClickUp,
                                     Google, GitHub Pages
                                     (Sparkle feed),
                                     OpenAI/Groq/Gemini.

          • network.server         — localhost listener for the
                                     Google OAuth redirect.

          • files.user-selected
                  .read-write       — NSOpenPanel + drag-drop
                                     attachments.

          • personal-information
                  .calendars        — EventKit access (Calendar
                                     RSVP bridge + future sync).

          • personal-information
                  .addressbook      — Contacts picker for
                                     attendee selection.

          • automation
                  .apple-events     — AppleScript bridge that
                                     sends RSVPs to Calendar.app.

          • application-groups      — REQUIRED by Sparkle's
                                     XPC services in sandbox.
                                     ID is `<TEAMID>.<bundle>`
                                     verbatim — Sparkle looks
                                     for that exact name.

          • developer
                  .usernotifications
                  .time-sensitive   — pierces Focus modes when
                                     the user opts in. Restricted
                                     entitlement — AMFI requires
                                     a recognized Team ID, which
                                     we now have.
    -->

    <key>com.apple.security.app-sandbox</key>
    <true/>

    <key>com.apple.security.network.client</key>
    <true/>

    <key>com.apple.security.network.server</key>
    <true/>

    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <key>com.apple.security.personal-information.calendars</key>
    <true/>

    <key>com.apple.security.personal-information.addressbook</key>
    <true/>

    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <key>com.apple.security.application-groups</key>
    <array>
        <string>CU544M36UD.com.painellunar.app</string>
    </array>

    <key>com.apple.developer.usernotifications.time-sensitive</key>
    <true/>
</dict>
</plist>
